PORT=3000
MONGO_URI=mongodb+srv://<user>:<senha>@cluster0.xxxxx.mongodb.net/calendario?retryWrites=true&w=majority
JWT_SECRET=uma_chave_secreta_grande_e_aleatoria

# Cloudinary (armazenamento de fotos/arquivos anexados aos eventos)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret

# Web Push (fallback de lembrete quando o WhatsApp está desconectado).
# Gerar um par novo com: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:seu-email@exemplo.com

# IA (gera título/descrição detalhada a partir de uma ideia curta em "Pedir atualização")
# Chave gratuita em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Watchlist: busca de capas (filme/série via TMDB, jogo via RAWG)
# TMDB: crie uma conta em https://www.themoviedb.org e gere a key em Configurações > API
TMDB_API_KEY=
# RAWG: gere a key gratuita em https://rawg.io/apidocs
RAWG_API_KEY=
